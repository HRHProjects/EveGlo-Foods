{
  "manifestVersion": "1.0",
  "featureId": "eveglo-glow-finder",
  "featureName": "Glow Finder",
  "featureType": "json-powered-shop-by-goal-product-engine",
  "brand": "EveGlō Foods",
  "localeDefault": "en-CA",
  "locales": [
    "en-CA",
    "fr-CA"
  ],
  "purpose": "Replace generic product cards with a guided product recommendation experience that helps visitors choose the right EveGlō product for their meal, goal, flavour, and time limit.",
  "removedIdeas": [
    "packaging hotspots",
    "static mockup gallery",
    "click-the-box callouts"
  ],
  "dataPolicy": {
    "sourceOfTruth": "EveGlō product package images are the primary source for product names, visible nutrition claims, pack sizes, and icons. Liviva is used only as a comparable reference because the product families closely match.",
    "doNotMentionComparableBrandInUI": true,
    "verifyBeforePublishing": true,
    "conflictHandling": "If EveGlō packaging conflicts with comparable reference data, show the EveGlō package value and mark the conflicting reference field as verify.",
    "publicFacingDisclaimer": "Product details should be checked against final approved labels before launch."
  },
